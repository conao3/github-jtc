VITE_GITHUB_APP_CLIENT_ID=
# Optional. When omitted, the frontend uses <current-origin>/login/callback.
# For a GitHub Pages project site, this is typically
# https://<owner>.github.io/<repository>/login/callback
VITE_GITHUB_APP_REDIRECT_URI=
# Set this to your deployed Worker URL, for example:
# https://github-jtc-auth-broker.<subdomain>.workers.dev/api/auth/github/exchange
VITE_GITHUB_APP_EXCHANGE_URL=
VITE_GITHUB_GRAPHQL_URL=https://api.github.com/graphql
