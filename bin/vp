#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
REAL_VP="$ROOT_DIR/node_modules/vite-plus/bin/vp"

if [[ ! -x "$REAL_VP" ]]; then
  echo "vite-plus binary not found: $REAL_VP" >&2
  exit 1
fi

if [[ "${1:-}" == "check" && "$#" -eq 1 ]]; then
  exec bun run "$ROOT_DIR/scripts/check.ts"
fi

exec "$REAL_VP" "$@"
