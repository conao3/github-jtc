{
  "name": "github-jtc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "check": "bun run scripts/check.ts",
    "check:vp": "vp check",
    "check:knip": "knip",
    "check:tsc": "tsc --noEmit",
    "test": "vp test",
    "graphql:schema": "mkdir -p graphql && curl -fsSL https://docs.github.com/public/fpt/schema.docs.graphql -o graphql/github.schema.graphql",
    "graphql:codegen": "graphql-codegen --config codegen.ts",
    "desktop:dev": "bun run build && electrobun dev",
    "desktop:run": "bun run build && electrobun run",
    "desktop:build": "bun run build && electrobun build",
    "desktop:build:stable": "bun run build && electrobun build --env=stable"
  },
  "dependencies": {
    "@apollo/client": "^4.1.9",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-query": "^5.100.8",
    "clsx": "2.1.1",
    "electrobun": "1.16.0",
    "graphql": "^16.13.2",
    "react": "19.2.5",
    "react-aria-components": "1.17.0",
    "react-dom": "19.2.5",
    "react-router-dom": "7.14.2",
    "tailwindcss": "4.2.4",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/client-preset": "^6.0.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@types/bun": "1.3.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "knip": "^6.11.0",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vite-plus": "0.1.20"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.20",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.20"
  },
  "packageManager": "bun@1.3.11"
}
